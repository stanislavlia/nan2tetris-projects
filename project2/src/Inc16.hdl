// File name: projects/2/Inc16.hdl
/**
 * 16-bit incrementer:
 * out = in + 1
 */
CHIP Inc16 {
    IN in[16];
    OUT out[16];

    PARTS:
    //set LSB to 1
    And16(a[1..15]=false, a[0]=true, b=true, out=one16);
    Add16(a=in, b=one16, out=out);
}